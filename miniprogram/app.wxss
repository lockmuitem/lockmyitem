page {
  min-height: 100%;
  color: #182d2a;
  background: #edf3f0;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 22rpx 24rpx 72rpx;
}

.section-title {
  margin: 28rpx 0 16rpx;
  color: #102524;
  font-size: 34rpx;
  font-weight: 800;
}

.muted {
  color: #667085;
}

.card {
  position: relative;
  margin-bottom: 20rpx;
  padding: 24rpx 24rpx 24rpx 28rpx;
  background: #fffdf7;
  border: 1rpx solid #dde6e1;
  border-radius: 8rpx;
  box-shadow: 0 8rpx 18rpx rgba(37, 59, 55, 0.045);
}

.card::before {
  position: absolute;
  top: 24rpx;
  bottom: 24rpx;
  left: 0;
  width: 6rpx;
  content: "";
  background: #0e6f68;
  border-radius: 0 8rpx 8rpx 0;
}

.button-primary,
.button-secondary,
.button-danger {
  height: 76rpx;
  margin: 0;
  padding: 0 28rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 76rpx;
}

.button-primary {
  color: #ffffff;
  background: #0e6f68;
}

.button-secondary {
  color: #0e6f68;
  background: #e3f1ed;
}

.button-danger {
  color: #b42318;
  background: #fee4e2;
}

.button-primary::after,
.button-secondary::after,
.button-danger::after {
  border: 0;
}

.tag {
  display: inline-flex;
  align-items: center;
  height: 44rpx;
  margin: 0 12rpx 12rpx 0;
  padding: 0 18rpx;
  color: #53645f;
  background: #e8eeeb;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.tag.active {
  color: #ffffff;
  background: #0e6f68;
}

.empty {
  padding: 72rpx 24rpx;
  color: #6b7280;
  text-align: center;
  background: #fffdf7;
  border: 1rpx dashed #cbd8d2;
  border-radius: 8rpx;
}

.surface-hero {
  position: relative;
  min-height: 204rpx;
  margin-bottom: 16rpx;
  padding: 34rpx 30rpx;
  overflow: hidden;
  color: #173330;
  background: #fffdf7;
  border: 1rpx solid #dce5df;
  border-radius: 8rpx;
  box-shadow: 0 14rpx 30rpx rgba(37, 59, 55, 0.08);
}

.surface-hero::after {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  width: 10rpx;
  content: "";
  background: #0e6f68;
  border: 0;
  border-radius: 0;
}

.surface-eyebrow,
.surface-title,
.surface-subtitle {
  position: relative;
  z-index: 1;
  display: block;
}

.surface-eyebrow {
  margin-bottom: 10rpx;
  color: #0e6f68;
  font-size: 20rpx;
  font-weight: 700;
}

.surface-title {
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.14;
}

.surface-subtitle {
  max-width: 500rpx;
  margin-top: 12rpx;
  color: #5f706b;
  font-size: 24rpx;
  line-height: 1.42;
}

.status-pill {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 14rpx;
  color: #0e6f68;
  background: #e3f1ed;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 700;
}
