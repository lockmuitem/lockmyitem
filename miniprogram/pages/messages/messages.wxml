<view class="page">
  <view class="section-title">消息中心</view>
  <view wx:if="{{notifications.length === 0}}" class="empty">暂无消息</view>
  <view wx:for="{{notifications}}" wx:key="_id" class="card notice" bindtap="goDetail" data-id="{{item.itemId}}">
    <view class="notice-type">{{labels[item.type] || '通知'}}</view>
    <text class="notice-content">{{item.content}}</text>
    <text class="notice-time">{{item.createdAt}}</text>
  </view>
</view>
