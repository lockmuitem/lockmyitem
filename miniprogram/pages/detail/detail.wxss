.detail-image {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 420rpx;
  margin-bottom: 20rpx;
  color: #0f766e;
  background: #e7f5f2;
  border-radius: 8rpx;
  font-size: 42rpx;
  font-weight: 800;
  overflow: hidden;
}

.detail-image image {
  width: 100%;
  height: 100%;
}

.detail-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.title {
  font-size: 38rpx;
  font-weight: 800;
}

.type-pill {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  color: #8a5a00;
  background: #fff4cc;
  border-radius: 6rpx;
  font-size: 24rpx;
}

.type-pill.lost {
  color: #1d4ed8;
  background: #dbeafe;
}

.desc {
  display: block;
  margin: 18rpx 0;
  color: #475467;
  line-height: 1.55;
}

.location-card {
  overflow: hidden;
}

.location-heading {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.location-name {
  display: block;
  margin-bottom: 8rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.location-badge {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  color: #0f766e;
  background: #e7f5f2;
  border-radius: 6rpx;
  font-size: 24rpx;
}

.location-guide {
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  color: #344054;
  background: #f8fafb;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  line-height: 1.45;
}

.nearby-list {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.nearby-label {
  color: #667085;
  font-size: 24rpx;
}

.nearby-pill {
  padding: 8rpx 12rpx;
  color: #475467;
  background: #eef2f5;
  border-radius: 6rpx;
  font-size: 22rpx;
}

.location-map {
  width: 100%;
  height: 360rpx;
  margin-top: 18rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.map-note {
  display: block;
  margin-top: 12rpx;
  color: #667085;
  font-size: 22rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.comment {
  margin-bottom: 14rpx;
  padding: 18rpx;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
}

.comment-name {
  display: block;
  margin-bottom: 8rpx;
  color: #0f766e;
  font-size: 24rpx;
  font-weight: 700;
}

.comment-content {
  color: #172026;
}

.small {
  padding: 28rpx;
}

.comment-box {
  display: grid;
  grid-template-columns: 1fr 128rpx;
  gap: 12rpx;
  margin-top: 24rpx;
}

.comment-box input {
  height: 76rpx;
  padding: 0 18rpx;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
}

.comment-box button {
  height: 76rpx;
  margin: 0;
  color: #ffffff;
  background: #0f766e;
  border-radius: 8rpx;
  font-size: 26rpx;
  line-height: 76rpx;
}
