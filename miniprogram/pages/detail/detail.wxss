.detail-image {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 390rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  color: #245B6B;
  background: #E6F1F3;
  border: 1rpx solid #D7E4E8;
  border-radius: 8rpx;
  font-size: 42rpx;
  font-weight: 900;
}

.detail-image::after {
  position: absolute;
  right: 22rpx;
  bottom: 18rpx;
  padding: 8rpx 14rpx;
  color: #61727A;
  content: "物品照片";
  background: rgba(255, 255, 255, 0.9);
  border-radius: 6rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.detail-image image {
  width: 100%;
  height: 100%;
}

.detail-card {
  padding-top: 26rpx;
}

.detail-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.title-block {
  min-width: 0;
}

.detail-kicker {
  display: block;
  margin-bottom: 8rpx;
  color: #245B6B;
  font-size: 22rpx;
  font-weight: 800;
}

.title {
  display: block;
  color: #172A33;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.22;
}

.type-pill {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  color: #8B5A18;
  background: #FFF0CF;
  border-radius: 6rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.type-pill.lost {
  color: #1d4ed8;
  background: #dbeafe;
}

.desc {
  display: block;
  margin: 18rpx 0;
  color: #475467;
  line-height: 1.55;
}

.tag-row {
  max-height: 96rpx;
  overflow: hidden;
}

.location-card {
  overflow: hidden;
}

.location-heading {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.location-name {
  display: block;
  margin-bottom: 8rpx;
  color: #172A33;
  font-size: 34rpx;
  font-weight: 900;
}

.location-badge {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  color: #245B6B;
  background: #E4F0F2;
  border-radius: 6rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.location-guide {
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  color: #344054;
  background: #F6FAFC;
  border: 1rpx solid #CDE0E5;
  border-radius: 8rpx;
  line-height: 1.45;
}

.nearby-list {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.nearby-label {
  color: #667085;
  font-size: 26rpx;
}

.nearby-pill {
  padding: 8rpx 12rpx;
  color: #475467;
  background: #E8F0F3;
  border-radius: 6rpx;
  font-size: 24rpx;
}

.location-map {
  width: 100%;
  height: 360rpx;
  margin-top: 18rpx;
  overflow: hidden;
  border: 1rpx solid #D7E4E8;
  border-radius: 8rpx;
}

.map-note {
  display: block;
  margin-top: 12rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.4;
}

.action-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.comment {
  margin-bottom: 14rpx;
  padding: 18rpx;
  background: #FFFFFF;
  border: 1rpx solid #D7E4E8;
  border-radius: 8rpx;
}

.comment-name,
.comment-content {
  display: block;
}

.comment-name {
  color: #245B6B;
  font-size: 26rpx;
  font-weight: 800;
}

.comment-content {
  margin-top: 8rpx;
  color: #172026;
  line-height: 1.45;
}

.comment-box {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 18rpx;
  padding: 12rpx;
  background: #FFFFFF;
  border: 1rpx solid #D7E4E8;
  border-radius: 8rpx;
}

.comment-box input {
  min-width: 0;
  flex: 1;
  height: 68rpx;
  padding: 0 16rpx;
  background: #F6FAFC;
  border-radius: 8rpx;
}

.comment-box button {
  flex: 0 0 auto;
  width: 112rpx;
  height: 68rpx;
  margin: 0;
  color: #ffffff;
  background: #245B6B;
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 68rpx;
}

.comment-box button::after {
  border: 0;
}

.empty.small {
  padding: 32rpx 24rpx;
}
