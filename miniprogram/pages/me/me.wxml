<view class="page">
  <view class="profile card">
    <view class="avatar">{{user.nickName ? user.nickName.slice(0, 1) : '微'}}</view>
    <view>
      <text class="name">{{user.nickName}}</text>
      <text class="muted">{{user.email || '未填写邮箱'}} · 校园互助账号</text>
    </view>
  </view>

  <view class="card profile-form">
    <view class="form-title">注册资料</view>
    <input class="profile-input" placeholder="昵称" value="{{profileForm.nickName}}" bindinput="onProfileInput" data-field="nickName" />
    <input class="profile-input" placeholder="邮箱，用于接收找回提醒" type="text" value="{{profileForm.email}}" bindinput="onProfileInput" data-field="email" />
    <button class="button-primary save-profile" bindtap="saveProfile">保存资料</button>
  </view>

  <view class="quick-actions">
    <button class="button-secondary" bindtap="goMessages">消息中心</button>
    <button class="button-primary" bindtap="goPublish">继续发布</button>
  </view>

  <view class="section-title">我的发布</view>
  <view wx:if="{{items.length === 0}}" class="empty">你还没有发布过线索</view>
  <view wx:for="{{items}}" wx:key="_id" class="card mine-card" bindtap="goDetail" data-id="{{item._id}}">
    <view>
      <text class="title">{{item.title}}</text>
      <text class="meta">{{item.status === 'returned' ? '已回家' : '寻找中'}} · {{item.category}}{{item.locationName ? ' · ' + item.locationName : ''}}</text>
    </view>
    <button
      wx:if="{{item.status === 'active'}}"
      class="small-action"
      catchtap="markReturned"
      data-id="{{item._id}}"
    >已回家</button>
    <button
      wx:else
      class="small-action secondary"
      catchtap="undoReturned"
      data-id="{{item._id}}"
    >撤回</button>
  </view>
</view>
