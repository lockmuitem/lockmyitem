.profile {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  color: #ffffff;
  background: #0f766e;
  border-radius: 50%;
  font-size: 38rpx;
  font-weight: 800;
}

.name {
  display: block;
  margin-bottom: 8rpx;
  font-size: 34rpx;
  font-weight: 800;
}

.quick-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

.mine-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.title,
.meta {
  display: block;
}

.title {
  font-weight: 700;
}

.meta {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.small-action {
  width: 132rpx;
  height: 60rpx;
  margin: 0;
  color: #ffffff;
  background: #0f766e;
  border-radius: 8rpx;
  font-size: 24rpx;
  line-height: 60rpx;
}

.small-action.secondary {
  color: #0f766e;
  background: #e7f5f2;
}
