.found-home {
  background: #F8FBFC;
}

.summary-card {
  display: flex;
  align-items: baseline;
  gap: 14rpx;
  margin-bottom: 20rpx;
  padding: 22rpx 24rpx;
  background: #FFFFFF;
  border: 1rpx solid #D7E4E8;
  border-radius: 8rpx;
}

.summary-number {
  color: #C4862F;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1;
}

.summary-label {
  color: #475467;
  font-size: 28rpx;
}

.found-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.badge {
  flex: 0 0 auto;
  padding: 10rpx 16rpx;
  color: #245B6B;
  background: #E4F0F2;
  border-radius: 6rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.item-copy {
  min-width: 0;
}

.title,
.meta {
  display: block;
}

.title {
  overflow: hidden;
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.meta {
  margin-top: 8rpx;
  overflow: hidden;
  color: #667085;
  font-size: 26rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}
