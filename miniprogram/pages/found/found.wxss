.intro {
  margin-bottom: 22rpx;
}

.found-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.badge {
  flex: 0 0 auto;
  padding: 10rpx 16rpx;
  color: #0f766e;
  background: #e7f5f2;
  border-radius: 6rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.title,
.meta {
  display: block;
}

.title {
  font-size: 32rpx;
  font-weight: 700;
}

.meta {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
}
