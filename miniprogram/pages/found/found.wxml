<view class="page">
  <view class="surface-hero found-home">
    <text class="surface-eyebrow">归还记录</text>
    <text class="surface-title">已找到</text>
    <text class="surface-subtitle">这里保留已经找回或归还的记录，方便同学确认线索状态。</text>
  </view>

  <view class="summary-card">
    <text class="summary-number">{{total}}</text>
    <text class="summary-label">件物品已经回家</text>
  </view>

  <view wx:if="{{items.length === 0}}" class="empty">还没有已找到记录</view>

  <view wx:for="{{items}}" wx:key="_id" class="card found-card" bindtap="goDetail" data-id="{{item._id}}">
    <view class="badge">已回家</view>
    <view class="item-copy">
      <text class="title">{{item.title}}</text>
      <text class="meta">{{item.category}}{{item.locationName ? ' · ' + item.locationName : ''}}</text>
    </view>
  </view>
</view>
