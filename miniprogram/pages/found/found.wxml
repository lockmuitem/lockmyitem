<view class="page">
  <view class="board-head">
    <text class="app-title">已找到</text>
    <text class="app-subtitle">归还成功的物品会留在这里，避免重复认领。</text>
  </view>

  <view class="summary-card">
    <text class="summary-number">{{total}}</text>
    <text class="summary-label">件物品已经回家</text>
  </view>

  <view wx:if="{{items.length === 0}}" class="empty">还没有已找到记录</view>

  <view class="feed-panel" wx:if="{{items.length > 0}}">
    <view wx:for="{{items}}" wx:key="_id" class="found-row" bindtap="goDetail" data-id="{{item._id}}">
      <view class="badge">已回家</view>
      <view class="item-copy">
        <text class="title">{{item.title}}</text>
        <text class="meta">{{item.category}}{{item.locationName ? ' · ' + item.locationName : ''}}</text>
      </view>
    </view>
  </view>
</view>
