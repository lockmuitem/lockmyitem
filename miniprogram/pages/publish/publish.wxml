<view class="page">
  <view class="surface-hero publish-hero">
    <text class="surface-eyebrow">发布线索</text>
    <text class="surface-title">{{form.type === 'lost' ? '发布寻物' : '发布招领'}}</text>
    <text class="surface-subtitle">上传图片、确认地点，系统会提取标签并提示潜在匹配。</text>
  </view>

  <view class="card">
    <view class="segmented" aria-label="发布类型">
      <view class="{{form.type === 'found' ? 'active' : ''}}" bindtap="setType" data-type="found" aria-role="button">我捡到了</view>
      <view class="{{form.type === 'lost' ? 'active' : ''}}" bindtap="setType" data-type="lost" aria-role="button">我丢了</view>
    </view>

    <button class="image-picker" bindtap="chooseImage">
      <image wx:if="{{form.imageUrls.length}}" src="{{form.imageUrls[0]}}" mode="aspectFill" />
      <text wx:else>上传图片，可留空</text>
    </button>
    <view wx:if="{{classifying}}" class="model-status">正在调用混元模型识别图片...</view>
    <view wx:if="{{form.visualDescription}}" class="model-desc">{{form.visualDescription}}</view>

    <input class="field" placeholder="物品标题，可不填" value="{{form.title}}" bindinput="onInput" data-field="title" />
    <textarea class="field textarea" placeholder="补充描述，可不填" value="{{form.description}}" bindinput="onInput" data-field="description" />

    <view class="row-label">分类，可自动识别或手动选择</view>
    <view wx:if="{{form.category}}" class="ai-result">
      <text>当前分类：{{form.category}}</text>
      <button bindtap="clearCategory">清除</button>
    </view>
    <scroll-view scroll-x class="category-bar">
      <view
        wx:for="{{categories}}"
        wx:key="*this"
        wx:if="{{item !== '全部'}}"
        class="tag {{form.category === item ? 'active' : ''}}"
        bindtap="setCategory"
        data-category="{{item}}"
      >{{item}}</view>
    </scroll-view>

    <view class="location-panel {{locationState}}">
      <view class="indoor-consent">
        <view>
          <text class="indoor-title">室内增强定位</text>
          <text class="indoor-copy">开启后仅在重新定位时采集 Wi-Fi/BLE 信号，用于辅助判断楼内地点；关闭时不会采集或上传。</text>
        </view>
        <switch checked="{{indoorPositioningEnabled}}" bindchange="toggleIndoorPositioning" color="#245B6B" />
      </view>
      <view class="location-head">
        <view>
          <view class="row-label">地点</view>
          <text class="location-tip">{{locationTip}}</text>
          <text wx:if="{{locationMeta}}" class="location-meta">{{locationMeta}}</text>
          <text wx:if="{{indoorMeta}}" class="indoor-meta">{{indoorMeta}}</text>
        </view>
        <button class="locate-button" loading="{{locating}}" bindtap="detectCampusLocation" aria-label="获取当前位置">{{locating ? '定位中' : '重新定位'}}</button>
      </view>
    </view>
    <input class="field" placeholder="搜索上科大校内地点，如 图书馆、食堂、宿舍" value="{{locationKeyword}}" bindinput="searchLocation" />
    <button wx:if="{{form.locationId}}" class="clear-location" bindtap="clearLocation">不选择地点</button>
    <view wx:if="{{locationCandidates.length > 1}}" class="candidate-list">
      <button
        wx:for="{{locationCandidates}}"
        wx:key="_id"
        class="candidate {{form.locationId === item._id ? 'active' : ''}}"
        bindtap="selectLocation"
        data-id="{{item._id}}"
        aria-label="选择{{item.name}}，{{item.distanceText}}"
      >
        <text>{{item.name}}</text>
        <text>{{item.distanceText}}</text>
      </button>
    </view>
    <view class="location-list">
      <view
        wx:for="{{locations}}"
        wx:key="_id"
        class="location-option {{form.locationId === item._id ? 'active' : ''}}"
        bindtap="selectLocation"
        data-id="{{item._id}}"
      >
        <text>{{item.name}}</text>
        <text>{{item.area}}</text>
      </view>
    </view>

    <view wx:if="{{potentialMatches.length}}" class="match-panel">
      <view class="match-title">可能是你的物品</view>
      <view
        wx:for="{{potentialMatches}}"
        wx:key="_id"
        class="match-item"
        bindtap="goMatchDetail"
        data-id="{{item._id}}"
      >
        <view>
          <text class="match-name">{{item.title}}</text>
          <text class="match-meta">{{item.locationName}} · 相似度 {{item.similarity}}%</text>
          <text wx:if="{{item.matchReasonText}}" class="match-reason">{{item.matchReasonText}}</text>
        </view>
        <text class="match-pill">查看</text>
      </view>
    </view>

    <button class="button-primary submit" bindtap="submit">发布</button>
  </view>
</view>
