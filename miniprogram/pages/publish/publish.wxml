<view class="page">
  <view class="section-title">补充线索</view>

  <view class="card">
    <view class="segmented">
      <view class="{{form.type === 'found' ? 'active' : ''}}" bindtap="setType" data-type="found">我捡到了</view>
      <view class="{{form.type === 'lost' ? 'active' : ''}}" bindtap="setType" data-type="lost">我丢了</view>
    </view>

    <button class="image-picker" bindtap="chooseImage">
      <image wx:if="{{form.imageUrls.length}}" src="{{form.imageUrls[0]}}" mode="aspectFill" />
      <text wx:else>上传图片，可留空</text>
    </button>

    <input class="field" placeholder="物品标题，可不填" value="{{form.title}}" bindinput="onInput" data-field="title" />
    <textarea class="field textarea" placeholder="补充描述，可不填" value="{{form.description}}" bindinput="onInput" data-field="description" />

    <view class="row-label">自动识别分类，可不选</view>
    <view wx:if="{{form.category}}" class="ai-result">
      <text>当前识别：{{form.category}}</text>
      <button bindtap="clearCategory">清除</button>
    </view>
    <scroll-view scroll-x class="category-bar">
      <view
        wx:for="{{categories}}"
        wx:key="*this"
        wx:if="{{item !== '全部'}}"
        class="tag {{form.category === item ? 'active' : ''}}"
        bindtap="setCategory"
        data-category="{{item}}"
      >{{item}}</view>
    </scroll-view>

    <view class="row-label">地点，可不选</view>
    <input class="field" placeholder="搜索地点，如 图书馆、食堂、宿舍" value="{{locationKeyword}}" bindinput="searchLocation" />
    <button wx:if="{{form.locationId}}" class="clear-location" bindtap="clearLocation">不选择地点</button>
    <view class="location-list">
      <view
        wx:for="{{locations}}"
        wx:key="_id"
        class="location-option {{form.locationId === item._id ? 'active' : ''}}"
        bindtap="selectLocation"
        data-id="{{item._id}}"
      >
        <text>{{item.name}}</text>
        <text>{{item.area}}</text>
      </view>
    </view>

    <button class="button-primary submit" bindtap="submit">发布</button>
  </view>
</view>
