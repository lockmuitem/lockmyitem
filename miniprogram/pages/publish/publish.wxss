.segmented {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8rpx;
  padding: 6rpx;
  background: #eef2f5;
  border-radius: 8rpx;
}

.segmented view {
  height: 64rpx;
  color: #475467;
  border-radius: 6rpx;
  text-align: center;
  line-height: 64rpx;
}

.segmented .active {
  color: #0f766e;
  background: #ffffff;
  font-weight: 700;
}

.image-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 280rpx;
  margin: 24rpx 0;
  color: #0f766e;
  background: #e7f5f2;
  border-radius: 8rpx;
  font-size: 30rpx;
}

.image-picker image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}

.model-status,
.model-desc {
  margin: -8rpx 0 18rpx;
  padding: 14rpx 18rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  line-height: 1.45;
}

.model-status {
  color: #0f766e;
  background: #e7f5f2;
}

.model-desc {
  color: #344054;
  background: #f8fafb;
  border: 1rpx solid #e5e7eb;
}

.field {
  width: 100%;
  min-height: 82rpx;
  margin-bottom: 18rpx;
  padding: 0 20rpx;
  background: #f8fafb;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.textarea {
  height: 150rpx;
  padding-top: 18rpx;
}

.row-label {
  margin: 18rpx 0 12rpx;
  color: #111827;
  font-weight: 700;
}

.location-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 18rpx;
}

.location-head .row-label {
  margin-top: 0;
}

.location-tip {
  display: block;
  margin-bottom: 12rpx;
  color: #667085;
  font-size: 24rpx;
}

.locate-button {
  width: 132rpx;
  height: 58rpx;
  margin: 0;
  padding: 0;
  color: #ffffff;
  background: #0f766e;
  border-radius: 8rpx;
  font-size: 24rpx;
  line-height: 58rpx;
}

.ai-result {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
  padding: 14rpx 18rpx;
  color: #0f766e;
  background: #e7f5f2;
  border-radius: 8rpx;
}

.ai-result button,
.clear-location {
  width: auto;
  height: 54rpx;
  margin: 0;
  padding: 0 18rpx;
  color: #0f766e;
  background: #ffffff;
  border-radius: 8rpx;
  font-size: 24rpx;
  line-height: 54rpx;
}

.category-bar {
  white-space: nowrap;
}

.clear-location {
  margin-bottom: 14rpx;
  background: #e7f5f2;
}

.candidate-list {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.candidate {
  flex: 0 0 auto;
  min-width: 190rpx;
  padding: 14rpx 16rpx;
  color: #344054;
  background: #f8fafb;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
}

.candidate text {
  display: block;
}

.candidate text:last-child {
  margin-top: 4rpx;
  color: #667085;
  font-size: 22rpx;
}

.candidate.active {
  color: #0f766e;
  background: #e7f5f2;
  border-color: #0f766e;
}

.location-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.location-option {
  padding: 18rpx;
  background: #f8fafb;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
}

.location-option text {
  display: block;
}

.location-option text:last-child {
  margin-top: 6rpx;
  color: #6b7280;
  font-size: 22rpx;
}

.location-option.active {
  color: #0f766e;
  background: #e7f5f2;
  border-color: #0f766e;
}

.match-panel {
  margin: 22rpx 0 8rpx;
  padding: 18rpx;
  background: #fff8e6;
  border: 1rpx solid #f6d58f;
  border-radius: 8rpx;
}

.match-title {
  margin-bottom: 12rpx;
  color: #7a4b00;
  font-weight: 700;
}

.match-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 14rpx 0;
  border-top: 1rpx solid rgba(122, 75, 0, 0.14);
}

.match-name,
.match-meta,
.match-reason {
  display: block;
}

.match-name {
  color: #111827;
  font-weight: 700;
}

.match-meta {
  margin-top: 6rpx;
  color: #7a4b00;
  font-size: 24rpx;
}

.match-reason {
  margin-top: 6rpx;
  color: #667085;
  font-size: 22rpx;
}

.match-pill {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  color: #ffffff;
  background: #c97700;
  border-radius: 6rpx;
  font-size: 24rpx;
}

.submit {
  width: 100%;
  margin-top: 14rpx;
}
