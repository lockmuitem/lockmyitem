.publish-hero {
  background: #FFFFFF;
}

.segmented {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8rpx;
  padding: 6rpx;
  background: #E8F0F3;
  border-radius: 8rpx;
}

.segmented view {
  height: 64rpx;
  color: #475467;
  border-radius: 6rpx;
  text-align: center;
  line-height: 64rpx;
}

.segmented .active {
  color: #245B6B;
  background: #ffffff;
  font-weight: 700;
}

.image-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 300rpx;
  margin: 24rpx 0;
  color: #245B6B;
  background: #F6FAFC;
  border: 1rpx dashed #A8CAD0;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: 800;
}

.image-picker image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}

.model-status,
.model-desc {
  margin: -8rpx 0 18rpx;
  padding: 14rpx 18rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  line-height: 1.45;
}

.model-status {
  color: #245B6B;
  background: #E4F0F2;
}

.model-error {
  margin: -8rpx 0 18rpx;
  padding: 14rpx 18rpx;
  color: #B42318;
  background: #FFF1F0;
  border: 1rpx solid #FECDCA;
  border-radius: 8rpx;
  font-size: 25rpx;
  line-height: 1.45;
}

.model-desc {
  color: #344054;
  background: #F6FAFC;
  border: 1rpx solid #D7E4E8;
}

.ai-process {
  margin: -8rpx 0 18rpx;
  padding: 18rpx;
  background: #F6FAFC;
  border: 1rpx solid #D7E4E8;
  border-radius: 8rpx;
}

.ai-process-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 12rpx;
  color: #172A33;
  font-size: 25rpx;
  font-weight: 900;
}

.ai-process-head text:last-child {
  flex: 0 0 auto;
  padding: 5rpx 10rpx;
  color: #245B6B;
  background: #E4F0F2;
  border-radius: 6rpx;
  font-size: 21rpx;
  font-weight: 800;
}

.ai-process-step {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-top: 10rpx;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.45;
}

.ai-step-dot {
  flex: 0 0 auto;
  width: 16rpx;
  height: 16rpx;
  margin-top: 10rpx;
  background: #C9D5DB;
  border-radius: 50%;
}

.ai-step-text {
  min-width: 0;
  flex: 1;
}

.ai-process-step.active {
  color: #245B6B;
  font-weight: 800;
}

.ai-process-step.active .ai-step-dot {
  background: #245B6B;
  box-shadow: 0 0 0 8rpx rgba(36, 91, 107, 0.1);
}

.ai-process-step.done {
  color: #344054;
}

.ai-process-step.done .ai-step-dot {
  background: #1f9d6a;
}

.ai-process-step.error {
  color: #B42318;
}

.ai-process-step.error .ai-step-dot {
  background: #D92D20;
}

.field {
  width: 100%;
  min-height: 82rpx;
  margin-bottom: 18rpx;
  padding: 0 20rpx;
  background: #F6FAFC;
  border: 1rpx solid #D7E4E8;
  border-radius: 8rpx;
  font-size: 30rpx;
}

.textarea {
  height: 150rpx;
  padding-top: 18rpx;
}

.row-label {
  margin: 18rpx 0 12rpx;
  color: #111827;
  font-weight: 700;
}

.location-panel {
  margin: 22rpx 0 16rpx;
  padding: 18rpx;
  background: #F6FAFC;
  border: 1rpx solid #D7E4E8;
  border-radius: 8rpx;
}

.location-panel.ok {
  background: #E4F0F2;
  border-color: #A8CAD0;
}

.location-panel.warn {
  background: #fff8e6;
  border-color: #f6d58f;
}

.location-panel.error {
  background: #fff1f0;
  border-color: #fecdca;
}

.location-head {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 14rpx;
}

.location-head .row-label {
  margin-top: 0;
  margin-bottom: 0;
}

.location-actions {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 14rpx;
  width: 100%;
}

.map-picker-button {
  flex: 0 0 176rpx;
  height: 62rpx;
  margin: 0;
  padding: 0;
  color: #245B6B;
  background: #ffffff;
  border: 1rpx solid #A8CAD0;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 62rpx;
}

.campus-map-shell {
  margin-top: 16rpx;
  overflow: hidden;
  background: #ffffff;
  border: 1rpx solid rgba(36, 91, 107, 0.16);
  border-radius: 8rpx;
}

.campus-map {
  width: 100%;
  height: 520rpx;
  background: #E8F0F3;
}

.campus-map-note {
  display: block;
  padding: 12rpx 16rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 1.4;
}

.location-confirm {
  margin-top: 16rpx;
  padding: 14rpx 16rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(36, 91, 107, 0.16);
  border-radius: 8rpx;
}

.location-confirm-row {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  min-height: 38rpx;
  color: #344054;
  font-size: 25rpx;
  line-height: 1.45;
}

.location-confirm-row text:first-child {
  flex: 0 0 auto;
  color: #667085;
  font-weight: 700;
}

.location-confirm-row text:last-child {
  min-width: 0;
  flex: 1;
  color: #172A33;
  font-weight: 800;
  word-break: break-all;
}

.location-confirm-note {
  display: block;
  margin-top: 8rpx;
  color: #245B6B;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.4;
}

.map-picker-button::after,
.candidate::after,
.image-picker::after,
.clear-location::after,
.ai-result button::after {
  border: 0;
}

.ai-result {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
  padding: 14rpx 18rpx;
  color: #245B6B;
  background: #E4F0F2;
  border-radius: 8rpx;
}

.ai-result button,
.clear-location {
  width: auto;
  height: 54rpx;
  margin: 0;
  padding: 0 18rpx;
  color: #245B6B;
  background: #ffffff;
  border-radius: 8rpx;
  font-size: 26rpx;
  line-height: 54rpx;
}

.category-bar {
  white-space: nowrap;
}

.clear-location {
  margin-bottom: 14rpx;
  background: #E4F0F2;
}

.candidate-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.candidate {
  display: flex;
  flex-direction: column;
  justify-content: center;
  width: 100%;
  min-height: 96rpx;
  margin: 0;
  padding: 14rpx 16rpx;
  color: #344054;
  background: #F6FAFC;
  border: 1rpx solid #D7E4E8;
  border-radius: 8rpx;
  font-size: 28rpx;
  line-height: 1.25;
  text-align: left;
}

.candidate text {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.candidate text:last-child {
  margin-top: 4rpx;
  color: #667085;
  font-size: 24rpx;
}

.candidate.active {
  color: #245B6B;
  background: #E4F0F2;
  border-color: #245B6B;
}

.location-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.location-option {
  padding: 18rpx;
  background: #F6FAFC;
  border: 1rpx solid #D7E4E8;
  border-radius: 8rpx;
}

.location-option text {
  display: block;
}

.location-option text:last-child {
  margin-top: 6rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.location-option.active {
  color: #245B6B;
  background: #E4F0F2;
  border-color: #245B6B;
}

.match-panel {
  margin: 22rpx 0 8rpx;
  padding: 18rpx;
  background: #fff8e6;
  border: 1rpx solid #f6d58f;
  border-radius: 8rpx;
}

.match-title {
  margin-bottom: 12rpx;
  color: #7a4b00;
  font-weight: 700;
}

.match-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 14rpx 0;
  border-top: 1rpx solid rgba(122, 75, 0, 0.14);
}

.match-name,
.match-meta,
.match-reason {
  display: block;
}

.match-name {
  color: #111827;
  font-weight: 700;
}

.match-meta {
  margin-top: 6rpx;
  color: #7a4b00;
  font-size: 26rpx;
}

.match-reason {
  margin-top: 6rpx;
  color: #667085;
  font-size: 24rpx;
}

.match-pill {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  color: #ffffff;
  background: #c97700;
  border-radius: 6rpx;
  font-size: 26rpx;
}

.submit {
  width: 100%;
  margin-top: 14rpx;
}
