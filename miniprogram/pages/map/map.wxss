.hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
  padding: 34rpx 30rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #2563eb 0%, #0f766e 100%);
  border-radius: 8rpx;
  box-shadow: 0 18rpx 36rpx rgba(37, 99, 235, 0.16);
}

.hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
}

.hero-subtitle {
  display: block;
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.84);
  font-size: 24rpx;
}

.hero-action {
  flex: 0 0 auto;
  width: 176rpx;
  height: 64rpx;
  margin: 0;
  padding: 0;
  color: #0f3a6d;
  background: #ffffff;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 64rpx;
}

.category-bar {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 18rpx;
}

.item-card {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
  padding: 20rpx;
  background: #ffffff;
  border: 1rpx solid rgba(16, 24, 40, 0.06);
  border-radius: 8rpx;
  box-shadow: 0 10rpx 26rpx rgba(16, 24, 40, 0.05);
}

.image-box {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 172rpx;
  width: 172rpx;
  height: 172rpx;
  color: #1d4ed8;
  background: #dbeafe;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 700;
  overflow: hidden;
}

.image-box image {
  width: 100%;
  height: 100%;
}

.item-main {
  min-width: 0;
  flex: 1;
}

.item-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.item-title {
  min-width: 0;
  color: #111827;
  font-size: 32rpx;
  font-weight: 700;
}

.type-pill {
  flex: 0 0 auto;
  padding: 6rpx 12rpx;
  color: #1d4ed8;
  background: #dbeafe;
  border-radius: 6rpx;
  font-size: 22rpx;
}

.item-desc {
  display: block;
  margin: 12rpx 0;
  color: #475467;
  font-size: 26rpx;
}

.item-meta {
  display: flex;
  gap: 14rpx;
  margin-bottom: 12rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.tag.light {
  color: #667085;
  background: #f2f4f7;
}

.publish-fab {
  position: fixed;
  right: 32rpx;
  bottom: 132rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  min-width: 112rpx;
  max-width: 112rpx;
  padding: 0;
  color: #ffffff;
  background: linear-gradient(135deg, #2563eb, #0f766e);
  border-radius: 50%;
  box-shadow: 0 14rpx 30rpx rgba(37, 99, 235, 0.26);
  z-index: 20;
}

.plus {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  font-size: 62rpx;
  font-weight: 300;
  line-height: 112rpx;
}
