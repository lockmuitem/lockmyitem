.map-panel {
  position: relative;
  width: 100%;
  height: 660rpx;
  margin-bottom: 22rpx;
  overflow: hidden;
  background: #dfe8ec;
  border: 1rpx solid rgba(16, 24, 40, 0.08);
  border-radius: 8rpx;
  box-shadow: 0 16rpx 38rpx rgba(16, 24, 40, 0.08);
}

.real-map {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.map-shade {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, rgba(5, 36, 42, 0.04), rgba(5, 36, 42, 0.18));
  pointer-events: none;
}

.map-source {
  position: absolute;
  left: 22rpx;
  top: 22rpx;
  padding: 8rpx 14rpx;
  color: #0f766e;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.pin {
  position: absolute;
  width: 44rpx;
  height: 44rpx;
  margin-left: -22rpx;
  margin-top: -22rpx;
  padding: 8rpx;
  background: #ffffff;
  border: 3rpx solid #0f766e;
  border-radius: 50%;
  box-shadow: 0 8rpx 18rpx rgba(15, 118, 110, 0.2);
}

.pin text {
  display: block;
  width: 100%;
  height: 100%;
  background: #0f766e;
  border-radius: 50%;
}

.pin.active {
  width: 58rpx;
  height: 58rpx;
  margin-left: -29rpx;
  margin-top: -29rpx;
  background: #fff4cc;
  border-color: #c97700;
}

.location-title {
  margin-bottom: 8rpx;
  font-size: 34rpx;
  font-weight: 800;
}

.map-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.compact {
  flex: 0 0 auto;
  height: 64rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
  line-height: 64rpx;
}

.mini-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding: 22rpx;
  background: #ffffff;
  border: 1rpx solid rgba(16, 24, 40, 0.06);
  border-radius: 8rpx;
  box-shadow: 0 8rpx 22rpx rgba(16, 24, 40, 0.04);
}

.mini-title,
.mini-meta {
  display: block;
}

.mini-title {
  font-weight: 700;
}

.mini-meta {
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.arrow {
  color: #98a2b3;
  font-size: 46rpx;
}
