.page {
  padding: 28rpx 22rpx 88rpx;
  background: #fbfaf6;
}

.board-head {
  margin: 10rpx 12rpx 24rpx;
}

.app-title,
.app-subtitle,
.notice-title,
.notice-subtitle,
.list-title,
.list-subtitle,
.item-title,
.item-desc {
  display: block;
}

.app-title {
  color: #315d99;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1.15;
}

.app-subtitle {
  margin-top: 12rpx;
  color: #66706f;
  font-size: 28rpx;
  line-height: 1.35;
}

.notice-banner {
  position: relative;
  height: 184rpx;
  margin-bottom: 28rpx;
  overflow: hidden;
  background: #f1f4fb;
  border: 1rpx solid #e1e5ef;
  border-radius: 10rpx;
}

.notice-image {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
  opacity: 0.58;
}

.notice-copy {
  position: relative;
  z-index: 1;
  max-width: 460rpx;
  padding: 42rpx 34rpx;
}

.notice-title {
  color: #315d99;
  font-size: 34rpx;
  font-weight: 900;
}

.notice-subtitle {
  margin-top: 14rpx;
  color: #596968;
  font-size: 28rpx;
}

.category-bar {
  width: 100%;
  margin-bottom: 26rpx;
  white-space: nowrap;
}

.tag {
  height: 58rpx;
  margin-right: 18rpx;
  padding: 0 24rpx;
  color: #5f6767;
  background: transparent;
  border-radius: 999rpx;
  font-size: 30rpx;
  line-height: 58rpx;
}

.tag.active {
  color: #ffffff;
  background: #315d99;
  font-weight: 800;
}

.section-bar {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin: 0 10rpx 18rpx;
}

.list-title {
  color: #315d99;
  font-size: 34rpx;
  font-weight: 900;
}

.list-subtitle {
  margin-top: 4rpx;
  color: #7a817f;
  font-size: 26rpx;
}

.sort-button {
  width: auto;
  height: 58rpx;
  margin: 0;
  padding: 0 24rpx;
  color: #315d99;
  background: #eef2fa;
  border-radius: 999rpx;
  font-size: 26rpx;
  line-height: 58rpx;
}

.sort-button::after {
  border: 0;
}

.feed-panel {
  overflow: hidden;
  background: #ffffff;
  border: 1rpx solid #e4e7ee;
  border-radius: 10rpx;
}

.item-row {
  display: flex;
  gap: 22rpx;
  padding: 24rpx;
  border-bottom: 1rpx solid #eceff5;
}

.item-row:last-child {
  border-bottom: 0;
}

.image-box {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 150rpx;
  width: 150rpx;
  height: 150rpx;
  overflow: hidden;
  color: #315d99;
  background: #eef2fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.image-box image {
  width: 100%;
  height: 100%;
}

.item-main {
  min-width: 0;
  flex: 1;
}

.item-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.item-title {
  min-width: 0;
  color: #1f2933;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.28;
}

.type-pill {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  color: #315d99;
  background: #eef2fa;
  border: 1rpx solid #ccd8ef;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.item-desc {
  display: -webkit-box;
  margin-top: 12rpx;
  overflow: hidden;
  color: #626b70;
  font-size: 28rpx;
  line-height: 1.45;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.item-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
  color: #727b80;
  font-size: 26rpx;
}

.pin-dot {
  display: block;
  width: 16rpx;
  height: 16rpx;
  background: #6d88bd;
  border: 4rpx solid #eef2fa;
  border-radius: 50%;
}

.tag.light {
  height: 40rpx;
  margin: 0;
  padding: 0 16rpx;
  color: #6a7275;
  background: #f1f3f2;
  font-size: 24rpx;
  line-height: 40rpx;
}
