.hero {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  min-height: 206rpx;
  margin-bottom: 16rpx;
  padding: 34rpx 30rpx;
  overflow: hidden;
  color: #ffffff;
  background: #365C9A;
  border: 1rpx solid rgba(54, 92, 154, 0.18);
  border-radius: 8rpx;
  box-shadow: 0 18rpx 36rpx rgba(54, 92, 154, 0.18);
}

.hero::after {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  width: 10rpx;
  height: auto;
  content: "";
  background: #C4862F;
  border: 0;
  border-radius: 0;
}

.hero-copy {
  position: relative;
  z-index: 1;
  min-width: 0;
}

.hero-eyebrow,
.hero-title,
.hero-subtitle,
.stat-value,
.stat-label {
  display: block;
}

.hero-eyebrow {
  margin-bottom: 12rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 20rpx;
  font-weight: 700;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.12;
}

.hero-subtitle {
  max-width: 390rpx;
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
  line-height: 1.42;
}

.hero-action {
  position: relative;
  z-index: 1;
  flex: 0 0 auto;
  width: 178rpx;
  height: 68rpx;
  margin: 0;
  padding: 0;
  color: #365C9A;
  background: #ffffff;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 68rpx;
}

.hero-action::after {
  border: 0;
}

.stats-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.stat-card {
  min-height: 104rpx;
  padding: 16rpx;
  background: #FFFFFF;
  border: 1rpx solid #D7E4E8;
  border-radius: 8rpx;
  box-shadow: 0 8rpx 22rpx rgba(16, 24, 40, 0.04);
}

.stat-value {
  color: #365C9A;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1;
}

.stat-label {
  margin-top: 10rpx;
  color: #667085;
  font-size: 22rpx;
}

.category-bar {
  width: 100%;
  margin-bottom: 18rpx;
  white-space: nowrap;
}

.item-card {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
  padding: 20rpx;
  position: relative;
  overflow: hidden;
  background: #FFFFFF;
  border: 1rpx solid #D7E4E8;
  border-radius: 8rpx;
  box-shadow: 0 10rpx 26rpx rgba(16, 24, 40, 0.05);
}

.item-card::before {
  position: absolute;
  top: 22rpx;
  bottom: 22rpx;
  left: 0;
  width: 6rpx;
  content: "";
  background: #365C9A;
  border-radius: 0 8rpx 8rpx 0;
}

.image-box {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 172rpx;
  width: 172rpx;
  height: 172rpx;
  overflow: hidden;
  color: #365C9A;
  background: #E9EEF9;
  border: 1rpx solid #CFD9F0;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.image-box image {
  width: 100%;
  height: 100%;
}

.item-main {
  min-width: 0;
  flex: 1;
}

.item-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.title-stack {
  min-width: 0;
}

.item-kicker {
  display: block;
  margin-bottom: 4rpx;
  color: #365C9A;
  font-size: 18rpx;
  font-weight: 800;
}

.item-title {
  display: block;
  min-width: 0;
  color: #111827;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.25;
}

.type-pill {
  flex: 0 0 auto;
  padding: 6rpx 12rpx;
  color: #365C9A;
  background: #E9EEF9;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.item-desc {
  display: -webkit-box;
  margin: 12rpx 0;
  overflow: hidden;
  color: #475467;
  font-size: 26rpx;
  line-height: 1.42;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.item-meta {
  display: flex;
  gap: 14rpx;
  margin-bottom: 12rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.tag-row {
  max-height: 58rpx;
  overflow: hidden;
}

.tag.light {
  color: #667085;
  background: #f2f4f7;
}

.publish-fab {
  position: fixed;
  right: 32rpx;
  bottom: 132rpx;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  min-width: 112rpx;
  max-width: 112rpx;
  padding: 0;
  color: #ffffff;
  background: #365C9A;
  border-radius: 50%;
  box-shadow: 0 14rpx 30rpx rgba(23, 54, 95, 0.26);
}

.plus {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  font-size: 62rpx;
  font-weight: 300;
  line-height: 112rpx;
}
