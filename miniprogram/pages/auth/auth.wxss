.auth-page {
  min-height: 100vh;
  padding: 76rpx 34rpx 48rpx;
  background: #f4faf8;
}

.auth-hero {
  margin-bottom: 42rpx;
}

.auth-mark,
.auth-title,
.auth-copy,
.field-label {
  display: block;
}

.auth-mark {
  color: #c4862f;
  font-size: 26rpx;
  font-weight: 900;
}

.auth-title {
  margin-top: 22rpx;
  color: #172a33;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1.18;
}

.auth-copy {
  margin-top: 18rpx;
  color: #61727a;
  font-size: 28rpx;
  line-height: 1.55;
}

.auth-card {
  padding: 30rpx;
  background: #ffffff;
  border: 1rpx solid #d7e4e8;
  border-radius: 14rpx;
  box-shadow: 0 18rpx 42rpx rgba(31, 107, 93, 0.08);
}

.wechat-button,
.submit-button {
  width: 100%;
  height: 88rpx;
  margin: 0;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 88rpx;
}

.wechat-button {
  color: #ffffff;
  background: #245b6b;
}

.submit-button {
  margin-top: 28rpx;
  color: #245b6b;
  background: #e4f0f2;
}

.wechat-button::after,
.submit-button::after {
  border: 0;
}

.form-block {
  margin-top: 28rpx;
}

.field-label {
  margin-bottom: 12rpx;
  color: #172a33;
  font-size: 26rpx;
  font-weight: 900;
}

.field,
.email-row {
  min-height: 88rpx;
  background: #f7fbfc;
  border: 1rpx solid #d7e4e8;
  border-radius: 12rpx;
}

.field {
  width: 100%;
  padding: 0 22rpx;
  font-size: 30rpx;
}

.email-row {
  display: flex;
  align-items: center;
}

.email-input {
  min-width: 0;
  flex: 1;
  height: 88rpx;
  padding: 0 22rpx;
  font-size: 30rpx;
}

.email-domain {
  flex: 0 0 auto;
  padding-right: 20rpx;
  color: #245b6b;
  font-size: 25rpx;
  font-weight: 900;
}
