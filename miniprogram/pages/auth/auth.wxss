.auth-page {
  min-height: 100vh;
  padding: 54rpx 28rpx;
  background: #EEF5F8;
}

.auth-card {
  position: relative;
  padding: 44rpx 34rpx 34rpx;
  overflow: hidden;
  background: #FFFFFF;
  border: 1rpx solid #D7E4E8;
  border-radius: 8rpx;
  box-shadow: 0 22rpx 48rpx rgba(23, 42, 51, 0.11);
}

.auth-card::before {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  width: 10rpx;
  content: "";
  background: #C4862F;
}

.auth-card::after {
  position: absolute;
  top: 0;
  right: 0;
  left: 10rpx;
  height: 12rpx;
  content: "";
  background: #245B6B;
}

.auth-mark,
.auth-title,
.auth-copy,
.field-label {
  display: block;
}

.auth-mark {
  color: #C4862F;
  font-size: 22rpx;
  font-weight: 800;
}

.auth-title {
  margin-top: 18rpx;
  color: #172A33;
  font-size: 46rpx;
  font-weight: 900;
  line-height: 1.18;
}

.auth-copy {
  margin-top: 16rpx;
  color: #61727A;
  font-size: 26rpx;
  line-height: 1.55;
}

.wechat-button,
.submit-button {
  width: 100%;
  height: 82rpx;
  margin: 30rpx 0 0;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 82rpx;
}

.wechat-button {
  color: #ffffff;
  background: #245B6B;
}

.submit-button {
  color: #245B6B;
  background: #E4F0F2;
}

.wechat-button::after,
.submit-button::after {
  border: 0;
}

.form-block {
  margin-top: 24rpx;
}

.field-label {
  margin-bottom: 10rpx;
  color: #172A33;
  font-size: 24rpx;
  font-weight: 800;
}

.field,
.email-row {
  min-height: 84rpx;
  background: #F6FAFC;
  border: 1rpx solid #D7E4E8;
  border-radius: 8rpx;
}

.field {
  width: 100%;
  padding: 0 20rpx;
  font-size: 28rpx;
}

.email-row {
  display: flex;
  align-items: center;
}

.email-input {
  min-width: 0;
  flex: 1;
  height: 84rpx;
  padding: 0 18rpx;
  font-size: 28rpx;
}

.email-domain {
  flex: 0 0 auto;
  padding-right: 18rpx;
  color: #245B6B;
  font-size: 24rpx;
  font-weight: 800;
}
