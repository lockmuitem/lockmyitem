<view class="page">
  <view class="board-head">
    <view>
      <text class="app-title">校园公告板</text>
      <text class="app-subtitle">上海科技大学 · 失物招领平台</text>
    </view>
  </view>

  <view class="notice-banner" bindtap="startPublish">
    <view class="notice-copy">
      <text class="notice-title">拾金不昧，传递温暖</text>
      <text class="notice-subtitle">如遇失物，请及时发布招领信息</text>
    </view>
    <image class="notice-image" src="/assets/notice/campus-board.jpg" mode="aspectFill" />
  </view>

  <scroll-view class="category-bar" scroll-x>
    <view
      wx:for="{{categories}}"
      wx:key="*this"
      class="tag {{activeCategory === item ? 'active' : ''}}"
      bindtap="selectCategory"
      data-category="{{item}}"
    >{{item}}</view>
  </scroll-view>

  <view class="section-bar" wx:if="{{items.length > 0}}">
    <view>
      <text class="list-title">近期拾到 · {{stats.total}} 条</text>
      <text class="list-subtitle">按最新发布排序</text>
    </view>
    <button class="sort-button" bindtap="startPublish">发布</button>
  </view>

  <view wx:if="{{items.length === 0}}" class="empty">暂时没有招领信息</view>

  <view class="feed-panel" wx:if="{{items.length > 0}}">
    <view wx:for="{{items}}" wx:key="_id" class="item-row" bindtap="goDetail" data-id="{{item._id}}">
      <view class="image-box">
        <image wx:if="{{item.thumbUrl}}" src="{{item.thumbUrl}}" mode="aspectFill" />
        <text wx:else>{{item.category}}</text>
      </view>
      <view class="item-main">
        <view class="item-head">
          <text class="item-title">{{item.title}}</text>
          <text class="type-pill found">招领中</text>
        </view>
        <text class="item-desc">{{item.description}}</text>
        <view class="item-meta" wx:if="{{item.locationName || item.locationDetail}}">
          <text class="pin-dot"></text>
          <text>{{item.locationName}}</text>
          <text class="tag light">{{item.category}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="safety-note">
    <text class="shield-dot"></text>
    <text>温馨提示：请勿发布他人隐私信息，招领成功后请及时下架。</text>
  </view>
</view>
