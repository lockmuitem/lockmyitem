.hero {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  min-height: 244rpx;
  margin-bottom: 18rpx;
  padding: 34rpx 28rpx 30rpx;
  overflow: hidden;
  color: #ffffff;
  background: #245B6B;
  border: 1rpx solid rgba(36, 91, 107, 0.18);
  border-radius: 8rpx;
  box-shadow: 0 18rpx 36rpx rgba(36, 91, 107, 0.2);
}

.hero::after {
  position: absolute;
  top: 0;
  bottom: 0;
  left: 0;
  width: 10rpx;
  height: auto;
  content: "";
  background: #C4862F;
  border: 0;
  border-radius: 0;
  transform: none;
}

.hero-glow {
  position: absolute;
  top: 42rpx;
  right: -44rpx;
  left: auto;
  width: 260rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  border-radius: 999rpx;
  transform: rotate(-18deg);
}

.hero-copy {
  position: relative;
  z-index: 1;
  min-width: 0;
  flex: 1;
}

.hero-eyebrow {
  display: block;
  margin-bottom: 12rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.hero-title {
  display: block;
  font-size: 52rpx;
  font-weight: 900;
  line-height: 1.12;
}

.hero-subtitle {
  display: block;
  max-width: 410rpx;
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 26rpx;
  line-height: 1.5;
}

.hero-panel {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  flex: 0 0 190rpx;
  padding: 18rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  border-radius: 8rpx;
  box-shadow: none;
}

.panel-label,
.panel-number {
  display: block;
  color: #245B6B;
  text-align: center;
}

.panel-label {
  font-size: 24rpx;
  font-weight: 700;
}

.panel-number {
  margin-top: 6rpx;
  font-size: 46rpx;
  font-weight: 900;
  line-height: 1;
}

.hero-action {
  width: 100%;
  height: 60rpx;
  margin: 0;
  margin-top: 16rpx;
  padding: 0;
  color: #ffffff;
  background: #C4862F;
  border-radius: 8rpx;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 60rpx;
}

.hero-action::after {
  border: 0;
}

.stats-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.stat-card {
  position: relative;
  min-height: 104rpx;
  padding: 18rpx 16rpx 16rpx;
  background: #FFFFFF;
  border: 1rpx solid #D7E4E8;
  border-radius: 8rpx;
  box-shadow: 0 8rpx 20rpx rgba(23, 42, 51, 0.04);
}

.stat-dot {
  display: block;
  width: 18rpx;
  height: 18rpx;
  margin-bottom: 14rpx;
  border-radius: 50%;
}

.active-dot {
  background: #245B6B;
}

.fresh-dot {
  background: #C4862F;
}

.done-dot {
  background: #365C9A;
}

.stat-value,
.stat-label {
  display: block;
}

.stat-value {
  color: #245B6B;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1;
}

.stat-label {
  margin-top: 10rpx;
  color: #667085;
  font-size: 24rpx;
}

.category-bar {
  width: 100%;
  margin-bottom: 22rpx;
  white-space: nowrap;
}

.list-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.list-title,
.list-subtitle {
  display: block;
}

.list-title {
  color: #101828;
  font-size: 32rpx;
  font-weight: 900;
}

.list-subtitle {
  color: #667085;
  font-size: 24rpx;
  text-align: right;
}

.item-card {
  position: relative;
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
  padding: 22rpx;
  overflow: hidden;
  background: #FFFFFF;
  border: 1rpx solid #D7E4E8;
  border-radius: 8rpx;
  box-shadow: 0 14rpx 34rpx rgba(16, 24, 40, 0.06);
}

.item-card::before {
  position: absolute;
  top: 22rpx;
  bottom: 22rpx;
  left: 0;
  width: 6rpx;
  content: "";
  background: #245B6B;
  border-radius: 0 8rpx 8rpx 0;
}

.image-box {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 172rpx;
  width: 172rpx;
  height: 172rpx;
  overflow: hidden;
  color: #2A8074;
  background: #E6F1F3;
  border: 1rpx solid #CDE0E5;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.image-box image {
  width: 100%;
  height: 100%;
}

.item-main {
  min-width: 0;
  flex: 1;
}

.item-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.title-stack {
  min-width: 0;
}

.item-kicker {
  display: block;
  margin-bottom: 4rpx;
  color: #2A8074;
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.item-title {
  display: block;
  min-width: 0;
  color: #111827;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.25;
}

.type-pill {
  flex: 0 0 auto;
  padding: 6rpx 12rpx;
  color: #8B5A18;
  background: #FFF0CF;
  border-radius: 6rpx;
  font-size: 24rpx;
  font-weight: 700;
}

.item-desc {
  display: -webkit-box;
  margin: 12rpx 0;
  overflow: hidden;
  color: #475467;
  font-size: 28rpx;
  line-height: 1.42;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.item-meta {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 12rpx;
  color: #6b7280;
  font-size: 26rpx;
}

.meta-mark {
  display: block;
  width: 14rpx;
  height: 14rpx;
  background: #C4862F;
  border-radius: 50%;
  box-shadow: 0 0 0 6rpx rgba(212, 148, 47, 0.12);
}

.tag-row {
  max-height: 58rpx;
  overflow: hidden;
}

.tag.light {
  color: #667085;
  background: #f2f4f7;
}

.publish-fab {
  position: fixed;
  right: 32rpx;
  bottom: 132rpx;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  min-width: 112rpx;
  max-width: 112rpx;
  padding: 0;
  color: #ffffff;
  background: #245B6B;
  border-radius: 50%;
  box-shadow: 0 14rpx 30rpx rgba(36, 91, 107, 0.28);
}

.plus {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  font-size: 62rpx;
  font-weight: 300;
  line-height: 112rpx;
}
