.hero {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  min-height: 206rpx;
  margin-bottom: 16rpx;
  padding: 34rpx 30rpx;
  overflow: hidden;
  color: #ffffff;
  background: #123c3a;
  border-radius: 8rpx;
  box-shadow: 0 18rpx 42rpx rgba(18, 60, 58, 0.2);
}

.hero::after {
  position: absolute;
  right: -70rpx;
  bottom: -86rpx;
  width: 230rpx;
  height: 230rpx;
  content: "";
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 50%;
}

.hero-copy {
  position: relative;
  z-index: 1;
  min-width: 0;
}

.hero-eyebrow {
  display: block;
  margin-bottom: 12rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.hero-title {
  display: block;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.12;
}

.hero-subtitle {
  display: block;
  max-width: 390rpx;
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
  line-height: 1.42;
}

.hero-action {
  position: relative;
  z-index: 1;
  flex: 0 0 auto;
  width: 178rpx;
  height: 68rpx;
  margin: 0;
  padding: 0;
  color: #123c3a;
  background: #ffffff;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 68rpx;
}

.hero-action::after {
  border: 0;
}

.stats-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.stat-card {
  min-height: 104rpx;
  padding: 16rpx;
  background: #ffffff;
  border: 1rpx solid rgba(16, 24, 40, 0.06);
  border-radius: 8rpx;
  box-shadow: 0 8rpx 22rpx rgba(16, 24, 40, 0.04);
}

.stat-value,
.stat-label {
  display: block;
}

.stat-value {
  color: #123c3a;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1;
}

.stat-label {
  margin-top: 10rpx;
  color: #667085;
  font-size: 22rpx;
}

.category-bar {
  width: 100%;
  margin-bottom: 18rpx;
  white-space: nowrap;
}

.item-card {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
  padding: 20rpx;
  background: #ffffff;
  border: 1rpx solid rgba(16, 24, 40, 0.06);
  border-radius: 8rpx;
  box-shadow: 0 10rpx 26rpx rgba(16, 24, 40, 0.05);
}

.image-box {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 172rpx;
  width: 172rpx;
  height: 172rpx;
  overflow: hidden;
  color: #0f766e;
  background: #e7f5f2;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.image-box image {
  width: 100%;
  height: 100%;
}

.item-main {
  min-width: 0;
  flex: 1;
}

.item-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.item-title {
  display: block;
  min-width: 0;
  color: #111827;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.25;
}

.type-pill {
  flex: 0 0 auto;
  padding: 6rpx 12rpx;
  color: #8a5a00;
  background: #fff4cc;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.item-desc {
  display: -webkit-box;
  margin: 12rpx 0;
  overflow: hidden;
  color: #475467;
  font-size: 26rpx;
  line-height: 1.42;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.item-meta {
  display: flex;
  gap: 14rpx;
  margin-bottom: 12rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.tag-row {
  max-height: 58rpx;
  overflow: hidden;
}

.tag.light {
  color: #667085;
  background: #f2f4f7;
}

.publish-fab {
  position: fixed;
  right: 32rpx;
  bottom: 132rpx;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  min-width: 112rpx;
  max-width: 112rpx;
  padding: 0;
  color: #ffffff;
  background: #0f766e;
  border-radius: 50%;
  box-shadow: 0 14rpx 30rpx rgba(15, 118, 110, 0.28);
}

.plus {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  font-size: 62rpx;
  font-weight: 300;
  line-height: 112rpx;
}
